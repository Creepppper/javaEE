# ==================================================
# 操作系统生成文件
# ==================================================
.DS_Store
Thumbs.db
Desktop.ini


# ==================================================
# 日志和临时文件
# ==================================================
*.log
logs/
log/
temp/
tmp/
*.tmp
*.swp
*.swo
*.bak


# ==================================================
# Java / Maven / Spring Boot
# ==================================================
# Maven 编译输出
**/target/

# Java 编译文件
*.class

# Java 打包文件
*.jar
*.war
*.ear

# 但是不要忽略 Maven Wrapper 自带的 jar
!**/.mvn/wrapper/maven-wrapper.jar

# JVM 崩溃日志
hs_err_pid*
replay_pid*

# Spring Boot 运行产生的 PID 文件
*.pid


# ==================================================
# Vue / Vite / Node.js
# ==================================================
# 依赖目录
**/node_modules/

# Vue/Vite 打包输出
**/dist/

# 前端缓存
**/.vite/
**/.cache/
**/.parcel-cache/

# npm / yarn / pnpm 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试覆盖率
**/coverage/


# ==================================================
# 环境变量与敏感配置
# ==================================================
# 前端环境变量
**/.env
**/.env.local
**/.env.*.local

# 保留环境变量示例文件
!**/.env.example

# 后端本地配置，可能包含数据库密码、密钥等
**/application-local.yml
**/application-local.yaml
**/application-local.properties

**/application-secret.yml
**/application-secret.yaml
**/application-secret.properties


# ==================================================
# VS Code
# ==================================================
.vscode/*

# 可以让团队共享推荐插件、调试配置和任务配置
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json


# ==================================================
# IntelliJ IDEA
# ==================================================
.idea/
*.iml
*.ipr
*.iws
out/


# ==================================================
# Eclipse / Spring Tool Suite
# ==================================================
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/


# ==================================================
# 用户上传文件
# ==================================================
# 如果系统运行时会保存证明材料或附件，避免提交到 Git
uploads/
upload/
files/


# ==================================================
# 本地数据库或数据文件
# ==================================================
*.db
*.sqlite
*.sqlite3


# ==================================================
# 其他构建产物
# ==================================================
build/
bin/